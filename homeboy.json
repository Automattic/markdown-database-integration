{
  "auto_cleanup": false,
  "changelog_target": "CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "markdown-database-integration",
  "remote_path": "wp-content/plugins/markdown-database-integration",
  "scripts": {
    "lint": [
      "php -l markdown-database-integration.php && for file in inc/*.php tests/*.php; do php -l \"$file\" || exit 1; done"
    ],
    "test": [
      "for test_file in tests/smoke-*.php; do php \"$test_file\" || exit 1; done"
    ]
  },
  "version_targets": [
    {
      "file": "markdown-database-integration.php",
      "pattern": "(?m)^\\s*\\*?\\s*Version:\\s*([0-9.]+)"
    },
    {
      "file": "markdown-database-integration.php",
      "pattern": "MARKDOWN_DB_VERSION',\\s*'([0-9.]+)'"
    }
  ]
}
