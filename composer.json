{
    "name": "chubes4/markdown-database-integration",
    "description": "WordPress database integration that stores content as markdown files.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "chubes4/block-format-bridge": "dev-main"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wp-packages.org"
        },
        {
            "type": "vcs",
            "url": "https://github.com/chubes4/block-format-bridge"
        },
        {
            "type": "vcs",
            "url": "https://github.com/chubes4/html-to-blocks-converter"
        }
    ],
    "autoload": {
        "classmap": [
            "inc/"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
