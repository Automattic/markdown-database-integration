{
    "name": "chubes4/markdown-database-integration",
    "description": "WordPress database integration that stores content as markdown files.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "chubes4/block-format-bridge": "^0.8"
    },
    "autoload": {
        "classmap": [
            "inc/"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "block-format-bridge",
            "type": "vcs",
            "url": "https://github.com/chubes4/block-format-bridge"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
